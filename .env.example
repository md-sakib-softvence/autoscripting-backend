# ── App ────────────────────────────────
NODE_ENV=development
APP_PORT=3000
API_PREFIX=api/v1
HOST_PORT=3001
FRONTEND_PORT=3000

# ── Database ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mydb
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://postgres:changeme@db:5432/mydb?schema=public

# ── Redis ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6380

# ── JWT ────────────────────────────────
JWT_SECRET=super_secret_change_in_production
JWT_EXPIRES_IN=7d

# ── Docker Hub ─────────────────────────
DOCKER_USERNAME=your_dockerhub_username

# ── GitHub Actions Secrets (set in repo settings, not here) ──
# SSH_HOST, SSH_USERNAME, SSH_PRIVATE_KEY
# TELEGRAM_TO, TELEGRAM_TOKEN
